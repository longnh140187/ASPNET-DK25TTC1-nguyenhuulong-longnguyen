@model HomeIndexViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<section class="relative pt-12 pb-20 overflow-hidden bg-primary-fixed/30">
<div class="container mx-auto px-4 lg:px-8 grid lg:grid-cols-2 gap-10 items-center">
<div class="z-10 space-y-6 max-w-xl">
<p class="font-script text-3xl text-secondary italic font-serif">Nấu ăn là yêu thương</p>
<h2 class="text-display-lg text-on-surface">
            Công thức ngon<br>
            cho <span class="text-primary-container">mọi bữa ăn</span>
</h2>
<p class="text-body-lg text-on-surface-variant">Khám phá hàng ngàn công thức nấu ăn ngon, dễ làm và những bí quyết giúp bữa cơm gia đình thêm ấm cúng.</p>
<div class="flex flex-wrap gap-4 pt-2">
<a asp-controller="Recipes" asp-action="Index"
   class="bg-primary-container hover:bg-orange-600 text-white font-semibold py-3 px-6 rounded-full flex items-center gap-2 transition-colors shadow-md shadow-orange-200">
<i class="fa-solid fa-fire text-yellow-300"></i> Khám phá ngay
</a>
</div>

<div class="grid grid-cols-3 gap-4 pt-8 border-t border-outline-variant mt-8">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center text-primary-container">
<i class="fa-solid fa-book-open"></i>
</div>
<div>
<p class="font-bold text-on-surface">10,000+</p>
<p class="text-label-md text-on-surface-variant">Công thức</p>
</div>
</div>
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center text-primary-container">
<i class="fa-solid fa-users"></i>
</div>
<div>
<p class="font-bold text-on-surface">50,000+</p>
<p class="text-label-md text-on-surface-variant">Thành viên</p>
</div>
</div>
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center text-primary-container">
<i class="fa-solid fa-utensils"></i>
</div>
<div>
<p class="font-bold text-on-surface">100,000+</p>
<p class="text-label-md text-on-surface-variant">Bữa ăn ngon</p>
</div>
</div>
</div>
</div>
<div class="relative z-0">
<img alt="Hero food plate" class="w-full max-w-lg mx-auto rounded-full shadow-2xl" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC370QMBRhCc8ocatKpd1SHDs3OM9kyYLyqoR4ulITLwyAf2cf4_pcOqmHkf1_gMDQ1tioJgOp1qNHArdpoXMs7GOfO3MTyJTxMDvJRu2hkUvvtdXFu711P_bGGsZZ2ghxDwpr6loG29lxpll1ui1UAdvE9Vw8DqNnSastiEWFhns5FjmcY7o2-G-yIh5t4S41B2kKxU7Qwh7AO0Nx3o4IxB3HyZNI3Y7PmSWgbuLbPDy7zDO-4hyIVZicmrQvrSqkoZhgxTzYn1Rg">

</div>
</div>
</section>

<section class="py-12 bg-surface-container-lowest w-full relative -mt-10 z-20">
<div class="container mx-auto px-4 lg:px-8">
<div class="bg-surface-container-lowest rounded-2xl shadow-lg border border-outline-variant p-6 overflow-x-auto no-scrollbar">
<div class="flex items-stretch w-full min-w-[720px] lg:min-w-0">
<a class="group flex flex-1 flex-col items-center gap-3 px-3 border-r border-outline-variant last:border-r-0" asp-controller="Recipes" asp-action="Index">
<div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-orange-50 text-2xl text-primary-container transition-all group-hover:bg-primary-container group-hover:text-white"><i class="fa-solid fa-bowl-food"></i></div>
<span class="flex min-h-[2.5rem] items-center justify-center text-center text-label-md leading-snug text-on-surface group-hover:text-primary-container">Món ăn hàng ngày</span>
</a>
<a class="group flex flex-1 flex-col items-center gap-3 px-3 border-r border-outline-variant last:border-r-0" asp-controller="Recipes" asp-action="Index">
<div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-green-50 text-2xl text-secondary transition-all group-hover:bg-secondary group-hover:text-white"><i class="fa-solid fa-leaf"></i></div>
<span class="flex min-h-[2.5rem] items-center justify-center text-center text-label-md leading-snug text-on-surface group-hover:text-secondary">Món chay thanh đạm</span>
</a>
<a class="group flex flex-1 flex-col items-center gap-3 px-3 border-r border-outline-variant last:border-r-0" asp-controller="Recipes" asp-action="Index">
<div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-yellow-50 text-2xl text-yellow-500 transition-all group-hover:bg-yellow-500 group-hover:text-white"><i class="fa-solid fa-cake-candles"></i></div>
<span class="flex min-h-[2.5rem] items-center justify-center text-center text-label-md leading-snug text-on-surface group-hover:text-yellow-600">Bánh ngon mỗi ngày</span>
</a>
<a class="group flex flex-1 flex-col items-center gap-3 px-3 border-r border-outline-variant last:border-r-0" asp-controller="Recipes" asp-action="Index">
<div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-pink-50 text-2xl text-pink-500 transition-all group-hover:bg-pink-500 group-hover:text-white"><i class="fa-solid fa-martini-glass-citrus"></i></div>
<span class="flex min-h-[2.5rem] items-center justify-center text-center text-label-md leading-snug text-on-surface group-hover:text-pink-600">Đồ uống hấp dẫn</span>
</a>
<a class="group flex flex-1 flex-col items-center gap-3 px-3 border-r border-outline-variant last:border-r-0" asp-controller="Recipes" asp-action="Index">
<div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-purple-50 text-2xl text-purple-500 transition-all group-hover:bg-purple-500 group-hover:text-white"><i class="fa-solid fa-earth-americas"></i></div>
<span class="flex min-h-[2.5rem] items-center justify-center text-center text-label-md leading-snug text-on-surface group-hover:text-purple-600">Ẩm thực bốn phương</span>
</a>
<a class="group flex flex-1 flex-col items-center gap-3 px-3 border-r border-outline-variant last:border-r-0" asp-controller="Recipes" asp-action="Index">
<div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-teal-50 text-2xl text-teal-500 transition-all group-hover:bg-teal-500 group-hover:text-white"><i class="fa-solid fa-lightbulb"></i></div>
<span class="flex min-h-[2.5rem] items-center justify-center text-center text-label-md leading-snug text-on-surface group-hover:text-teal-600">Mẹo vặt nhà bếp</span>
</a>
</div>
</div>
</div>
</section>

<div class="container mx-auto px-4 lg:px-8 grid lg:grid-cols-3 gap-8 py-8">

<div class="lg:col-span-2 space-y-8">
<div class="flex justify-between items-end border-b border-outline-variant pb-2">
<h2 class="text-headline-md text-on-surface flex items-center gap-2">
            Công thức nổi bật <i class="fa-solid fa-leaf text-secondary text-lg"></i>
</h2>
<a class="text-primary-container font-medium flex items-center gap-1 text-label-md" asp-controller="Recipes" asp-action="Index">
            Xem tất cả <i class="fa-solid fa-arrow-right"></i>
</a>
</div>
<div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
@if (!Model.FeaturedRecipes.Any())
{
    <div class="sm:col-span-2 md:col-span-3 text-center py-12 text-on-surface-variant">
        Chưa có công thức nổi bật.
    </div>
}
else
{
    @foreach (var recipe in Model.FeaturedRecipes)
    {
        <partial name="_FeaturedRecipeCard" model="recipe" />
    }
}
</div>
</div>

<div class="space-y-8">

<div class="bg-surface-container-lowest rounded-2xl p-6 border border-outline-variant shadow-sm">
<h3 class="text-headline-sm text-on-surface mb-4 flex items-center gap-2 border-b border-outline-variant pb-2">
<i class="fa-solid fa-heart text-primary-container"></i> Món ăn được yêu thích
          </h3>
<div class="space-y-4">
@if (!Model.RandomPopularRecipes.Any())
{
    <p class="text-sm text-on-surface-variant text-center py-4">Chưa có công thức nào.</p>
}
else
{
    @for (var i = 0; i < Model.RandomPopularRecipes.Count; i++)
    {
        <partial name="_PopularRecipeItem" model="(Model.RandomPopularRecipes[i], i + 1)" />
    }
}
</div>
<a asp-controller="Recipes" asp-action="Index" class="block w-full mt-6 py-2 border border-primary-container text-primary-container font-medium rounded-full hover:bg-primary-container hover:text-white transition-colors text-sm text-center">
            Xem tất cả món ngon <i class="fa-solid fa-arrow-right text-xs"></i>
</a>
</div>

<div class="bg-surface-container-low rounded-2xl p-6 relative overflow-hidden border border-outline-variant shadow-sm">
<div class="relative z-10">
<h3 class="font-bold text-on-surface mb-2 text-headline-sm">Đăng ký nhận bản tin</h3>
<p class="text-body-md text-on-surface-variant mb-4">Nhận ngay công thức mới nhất và mẹo vặt nấu ăn hay mỗi tuần!</p>
<form class="space-y-3">
<input class="w-full px-4 py-2 rounded-full border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none" placeholder="Nhập email của bạn..." type="email">
<button class="w-full bg-primary-container hover:bg-orange-600 text-white font-medium py-2 rounded-full transition-colors text-sm" type="submit">Đăng ký</button>
</form>
</div>

<div class="absolute -bottom-4 -right-4 w-24 h-24 opacity-20">
<i class="fa-solid fa-leaf text-secondary text-7xl"></i>
</div>
</div>
</div>
</div>

<section class="container mx-auto px-4 lg:px-8 py-8 grid lg:grid-cols-2 gap-8 border-t border-outline-variant mt-8">

<div>
<div class="flex justify-between items-end border-b border-outline-variant pb-2 mb-6">
<h2 class="text-headline-md text-on-surface flex items-center gap-2">
<i class="fa-solid fa-book-open text-primary-container text-lg"></i> Bài viết mới
      </h2>
<a class="text-primary-container font-medium flex items-center gap-1 text-label-md" asp-controller="Blogs" asp-action="Index">
        Xem tất cả <i class="fa-solid fa-arrow-right"></i>
</a>
</div>
<div class="space-y-6">
@if (!Model.LatestBlogs.Any())
{
    <p class="text-sm text-on-surface-variant text-center py-6">Chưa có bài viết nào.</p>
}
else
{
    @foreach (var blog in Model.LatestBlogs)
    {
        <partial name="_LatestBlogItem" model="blog" />
    }
}
</div>
</div>

<div class="bg-surface-container-low rounded-2xl p-6 border border-outline-variant shadow-sm relative overflow-hidden">
<div class="flex justify-between items-end border-b border-outline-variant pb-2 mb-6 relative z-10">
<h2 class="text-headline-md text-on-surface flex items-center gap-2">
<i class="fa-solid fa-lightbulb text-yellow-500 text-lg"></i> Bí quyết nấu ăn ngon
      </h2>
</div>
<div class="space-y-6 relative z-10 max-w-sm">
<div class="flex gap-4">
<div class="w-10 h-10 rounded-full bg-secondary-fixed flex items-center justify-center text-on-secondary-fixed shrink-0">
<i class="fa-solid fa-basket-shopping"></i>
</div>
<div>
<h4 class="font-bold text-on-surface text-sm">Chọn nguyên liệu tươi ngon</h4>
<p class="text-body-md text-on-surface-variant mt-1">Nguyên liệu tươi là yếu tố quan trọng quyết định hương vị món ăn.</p>
</div>
</div>
<div class="flex gap-4">
<div class="w-10 h-10 rounded-full bg-secondary-fixed flex items-center justify-center text-on-secondary-fixed shrink-0">
<i class="fa-solid fa-spoon"></i>
</div>
<div>
<h4 class="font-bold text-on-surface text-sm">Nêm nếm đúng cách</h4>
<p class="text-body-md text-on-surface-variant mt-1">Nêm nếm gia vị vừa đủ giúp món ăn đậm đà và hấp dẫn hơn.</p>
</div>
</div>
<div class="flex gap-4">
<div class="w-10 h-10 rounded-full bg-secondary-fixed flex items-center justify-center text-on-secondary-fixed shrink-0">
<i class="fa-solid fa-snowflake"></i>
</div>
<div>
<h4 class="font-bold text-on-surface text-sm">Cách bảo quản thực phẩm</h4>
<p class="text-body-md text-on-surface-variant mt-1">Bảo quản đúng cách giúp thực phẩm tươi lâu hơn và giữ được dinh dưỡng.</p>
</div>
</div>
</div>

<div class="absolute right-0 top-0 h-full w-1/3 md:w-1/2 opacity-30 md:opacity-100">
<img alt="Món ăn gia đình Việt Nam" class="h-full w-full object-cover object-left mask-image-linear" src="~/images/food.png" asp-append-version="true">
</div>
</div>
</section>

