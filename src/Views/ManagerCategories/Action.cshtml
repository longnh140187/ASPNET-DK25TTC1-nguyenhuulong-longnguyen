@model CategoryFormViewModel
@{
    Layout = "_LayoutAdmin";
    ViewData["ActiveMenu"] = "categories";
    var pageTitle = Model.IsEdit ? "Sửa danh mục" : "Thêm danh mục";
    ViewData["Title"] = pageTitle;
    ViewData["HeaderTitle"] = pageTitle;
    ViewData["HeaderSubtitle"] = Model.IsEdit ? "Cập nhật thông tin danh mục" : "Tạo danh mục mới cho website";
}

<partial name="_AdminPageStart" />

<a asp-controller="ManagerCategories" asp-action="Index" class="admin-link-back">
    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
    Quay lại danh sách
</a>

<div class="admin-card admin-card--padded max-w-2xl">
    <form asp-controller="ManagerCategories" asp-action="Action" asp-route-id="@Model.Id" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

        <div>
            <label asp-for="Name" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <input asp-for="Name"
                   class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none" />
            <span asp-validation-for="Name" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Color" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <div class="relative">
                <button type="button" id="colorPickerToggle"
                        class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest hover:border-primary-container transition-colors text-left">
                    <span id="colorPreview" class="w-8 h-8 rounded-md border border-outline-variant shrink-0 bg-gray-200"></span>
                    <span id="colorValue" class="text-sm text-on-surface-variant font-mono">Chọn màu...</span>
                    <span class="material-symbols-outlined text-on-surface-variant ml-auto text-[18px]">palette</span>
                </button>
                <input type="hidden" asp-for="Color" id="ColorInput" />
                <div id="colorPalette" class="hidden absolute z-20 mt-2 p-4 bg-surface-container-lowest border border-outline-variant rounded-xl shadow-lg w-full max-w-sm">
                    <p class="text-xs text-on-surface-variant mb-3">Chọn màu cho danh mục</p>
                    <div id="colorSwatches" class="grid grid-cols-5 gap-2 mb-3"></div>
                    <div class="flex items-center gap-2 pt-3 border-t border-outline-variant">
                        <label class="text-xs text-on-surface-variant shrink-0">Tùy chỉnh:</label>
                        <input type="color" id="customColorInput" class="w-10 h-8 rounded cursor-pointer border-0 p-0" value="#FF6B00" />
                        <input type="text" id="customColorHex" maxlength="7"
                               class="flex-1 px-3 py-1.5 rounded-lg border border-outline-variant text-sm font-mono outline-none focus:border-primary-container"
                               placeholder="#FF6B00" />
                    </div>
                </div>
            </div>
            <span asp-validation-for="Color" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Description" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <textarea asp-for="Description" rows="4"
                      class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none resize-y"></textarea>
            <span asp-validation-for="Description" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Order" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <input asp-for="Order" type="number" min="0"
                   class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none" />
            <span asp-validation-for="Order" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Status" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <select asp-for="Status"
                    class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none">
                <option value="@((int)RecordStatus.Active)">Hoạt động</option>
                <option value="@((int)RecordStatus.Inactive)">Ẩn</option>
                <option value="@((int)RecordStatus.Draft)">Nháp</option>
            </select>
            <span asp-validation-for="Status" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div class="flex items-center gap-3 pt-2">
            <button type="submit" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">save</span>
                @(Model.IsEdit ? "Cập nhật" : "Tạo mới")
            </button>
            <a asp-controller="ManagerCategories" asp-action="Index"
               class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors text-sm">
                Hủy
            </a>
        </div>
    </form>
</div>

<partial name="_AdminPageEnd" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/category-form.js" asp-append-version="true"></script>
}
