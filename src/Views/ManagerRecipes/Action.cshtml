@model RecipeFormViewModel
@{
    Layout = "_LayoutAdmin";
    ViewData["ActiveMenu"] = "recipes";
    var isClone = ViewData["IsClone"] as bool? == true;
    var pageTitle = isClone ? "Nhân bản công thức" : Model.IsEdit ? "Sửa công thức" : "Thêm công thức";
    ViewData["Title"] = pageTitle;
    ViewData["HeaderTitle"] = pageTitle;
    ViewData["HeaderSubtitle"] = isClone
        ? "Chỉnh sửa thông tin và lưu thành công thức mới"
        : Model.IsEdit ? "Cập nhật thông tin công thức" : "Tạo công thức mới";
}

<partial name="_AdminPageStart" />

<a asp-controller="ManagerRecipes" asp-action="Index" class="admin-link-back">
    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
    Quay lại danh sách
</a>

<div class="admin-card admin-card--padded">
    <form asp-controller="ManagerRecipes" asp-action="Action" asp-route-id="@Model.Id"
          method="post" enctype="multipart/form-data" class="space-y-6" id="recipeForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label asp-for="CategoryId" class="block text-sm font-medium text-on-surface mb-1.5"></label>
                <select asp-for="CategoryId"
                        class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none">
                    <option value="">-- Chọn danh mục --</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-red-600 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="Title" class="block text-sm font-medium text-on-surface mb-1.5"></label>
                <input asp-for="Title"
                       class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none" />
                <span asp-validation-for="Title" class="text-red-600 text-xs mt-1 block"></span>
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-on-surface mb-1.5">Ảnh thumbnail</label>
            <div class="flex flex-col sm:flex-row gap-4 items-start">
                @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                {
                    <img id="thumbnailPreview" src="@Model.ThumbnailUrl" alt="Thumbnail"
                         class="w-32 h-32 object-cover rounded-lg border border-outline-variant" />
                }
                else
                {
                    <div id="thumbnailPreviewPlaceholder"
                         class="w-32 h-32 rounded-lg border border-dashed border-outline-variant flex items-center justify-center text-on-surface-variant text-xs text-center px-2">
                        Chưa có ảnh
                    </div>
                    <img id="thumbnailPreview" src="" alt="Thumbnail" class="hidden w-32 h-32 object-cover rounded-lg border border-outline-variant" />
                }
                <div class="flex-1">
                    <input asp-for="ThumbnailFile" type="file" accept=".png,.jpg,.jpeg,.gif,.webp,.svg,image/*"
                           id="thumbnailFileInput"
                           class="block w-full text-sm text-on-surface-variant file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-primary-fixed file:text-primary-container file:font-medium hover:file:bg-orange-100" />
                    <input type="hidden" asp-for="ThumbnailUrl" id="ThumbnailUrl" />
                    <p class="text-xs text-on-surface-variant mt-2">Hỗ trợ: png, jpg, jpeg, gif, webp, svg. Tối đa 5MB.</p>
                    <span asp-validation-for="ThumbnailFile" class="text-red-600 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <div>
            <label asp-for="Summary" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <textarea asp-for="Summary" rows="2"
                      class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none resize-y"></textarea>
        </div>

        <div>
            <label asp-for="Content" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <textarea asp-for="Content" rows="5"
                      class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none resize-y"></textarea>
        </div>

        <!-- Ingredients -->
        <details class="border border-outline-variant rounded-lg overflow-hidden" open>
            <summary class="cursor-pointer px-4 py-3 bg-surface-container-low font-medium text-on-surface">
                Nguyên liệu
            </summary>
            <div class="p-4 space-y-3">
                <div id="ingredientsList" class="space-y-3"></div>
                <button type="button" id="addIngredientBtn"
                        class="inline-flex items-center gap-1 text-sm text-primary-container hover:text-orange-600 font-medium">
                    <span class="material-symbols-outlined text-[18px]">add</span> Thêm nguyên liệu
                </button>
                <input type="hidden" asp-for="IngredientsJson" id="IngredientsJson" />
                <span asp-validation-for="IngredientsJson" class="text-red-600 text-xs block"></span>
            </div>
        </details>

        <!-- Steps -->
        <details class="border border-outline-variant rounded-lg overflow-hidden" open>
            <summary class="cursor-pointer px-4 py-3 bg-surface-container-low font-medium text-on-surface">
                Các bước nấu
            </summary>
            <div class="p-4 space-y-3">
                <div id="stepsList" class="space-y-3"></div>
                <button type="button" id="addStepBtn"
                        class="inline-flex items-center gap-1 text-sm text-primary-container hover:text-orange-600 font-medium">
                    <span class="material-symbols-outlined text-[18px]">add</span> Thêm bước
                </button>
                <input type="hidden" asp-for="StepsJson" id="StepsJson" />
                <span asp-validation-for="StepsJson" class="text-red-600 text-xs block"></span>
            </div>
        </details>

        <!-- Nutrition -->
        <details class="border border-outline-variant rounded-lg overflow-hidden">
            <summary class="cursor-pointer px-4 py-3 bg-surface-container-low font-medium text-on-surface">
                Dinh dưỡng
            </summary>
            <div class="p-4 grid grid-cols-2 md:grid-cols-4 gap-4">
                <div>
                    <label asp-for="Nutrition.Calories" class="block text-sm font-medium text-on-surface mb-1.5">Calories</label>
                    <input asp-for="Nutrition.Calories" type="number" min="0"
                           class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest text-sm outline-none focus:border-primary-container" />
                </div>
                <div>
                    <label asp-for="Nutrition.Protein" class="block text-sm font-medium text-on-surface mb-1.5">Protein (g)</label>
                    <input asp-for="Nutrition.Protein" type="number" min="0"
                           class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest text-sm outline-none focus:border-primary-container" />
                </div>
                <div>
                    <label asp-for="Nutrition.Carbs" class="block text-sm font-medium text-on-surface mb-1.5">Carbs (g)</label>
                    <input asp-for="Nutrition.Carbs" type="number" min="0"
                           class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest text-sm outline-none focus:border-primary-container" />
                </div>
                <div>
                    <label asp-for="Nutrition.Fat" class="block text-sm font-medium text-on-surface mb-1.5">Fat (g)</label>
                    <input asp-for="Nutrition.Fat" type="number" min="0"
                           class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest text-sm outline-none focus:border-primary-container" />
                </div>
            </div>
        </details>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            <div>
                <label asp-for="CookingTimeMinutes" class="block text-sm font-medium text-on-surface mb-1.5"></label>
                <input asp-for="CookingTimeMinutes" type="number" min="0"
                       class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest text-sm outline-none focus:border-primary-container" />
            </div>
            <div>
                <label asp-for="Servings" class="block text-sm font-medium text-on-surface mb-1.5"></label>
                <input asp-for="Servings" type="number" min="1"
                       class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest text-sm outline-none focus:border-primary-container" />
            </div>
            <div>
                <label asp-for="Difficulty" class="block text-sm font-medium text-on-surface mb-1.5"></label>
                <select asp-for="Difficulty"
                        class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest text-sm outline-none focus:border-primary-container">
                    <option value="EASY">Dễ</option>
                    <option value="MEDIUM">Trung bình</option>
                    <option value="HARD">Khó</option>
                </select>
            </div>
        </div>

        <div class="flex flex-wrap items-center gap-6">
            <label class="inline-flex items-center gap-2 cursor-pointer">
                <input asp-for="IsFeatured" type="checkbox"
                       class="w-4 h-4 rounded border-outline-variant text-primary-container focus:ring-primary-container" />
                <span class="text-sm text-on-surface">@Html.DisplayNameFor(m => m.IsFeatured)</span>
            </label>

            <div class="flex-1 min-w-[200px]">
                <label asp-for="Status" class="block text-sm font-medium text-on-surface mb-1.5"></label>
                <select asp-for="Status"
                        class="w-full max-w-xs px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest text-sm outline-none focus:border-primary-container">
                    <option value="@((int)RecordStatus.Active)">Hoạt động</option>
                    <option value="@((int)RecordStatus.Inactive)">Ẩn</option>
                    <option value="@((int)RecordStatus.Draft)">Nháp</option>
                </select>
            </div>
        </div>

        <div class="flex items-center gap-3 pt-2">
            <button type="submit" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">save</span>
                @(Model.IsEdit ? "Cập nhật" : "Tạo mới")
            </button>
            <a asp-controller="ManagerRecipes" asp-action="Index"
               class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors text-sm">
                Hủy
            </a>
        </div>
    </form>
</div>

<partial name="_AdminPageEnd" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/recipe-form.js" asp-append-version="true"></script>
}
