@model IEnumerable<Recipe>
@{
    Layout = "_LayoutAdmin";
    ViewData["ActiveMenu"] = "recipes";
    ViewData["Title"] = "Quản lý công thức";
    ViewData["HeaderTitle"] = "Công thức";
    ViewData["HeaderSubtitle"] = "Quản lý danh sách công thức nấu ăn";
}

@functions {
    (string Label, string BadgeClass) GetStatusBadge(int status) => status switch
    {
        (int)RecordStatus.Active => ("Hoạt động", "bg-green-100 text-green-700 border-green-200"),
        (int)RecordStatus.Draft => ("Nháp", "bg-yellow-100 text-yellow-700 border-yellow-200"),
        _ => ("Ẩn", "bg-gray-100 text-gray-600 border-gray-200")
    };
}

<partial name="_AdminPageStart" />

<div class="admin-toolbar">
    <a asp-controller="ManagerRecipes" asp-action="Action" class="admin-btn-primary">
        <span class="material-symbols-outlined text-[18px]">add</span>
        Thêm công thức
    </a>
</div>

<div class="admin-card">
    <div class="admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th class="text-center">Featured</th>
                    <th>Status</th>
                    <th class="text-right">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-on-surface-variant py-8">
                            Chưa có công thức nào. Hãy thêm công thức đầu tiên.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        var (statusLabel, statusClass) = GetStatusBadge(item.Status);
                        <tr>
                            <td>
                                <div class="admin-table-name-cell">
                                    <partial name="_AdminListThumbnail" model="item.ThumbnailUrl" />
                                    <span class="font-medium text-on-surface">@item.Title</span>
                                </div>
                            </td>
                            <td class="text-center">
                                @if (item.IsFeatured)
                                {
                                    <span class="material-symbols-outlined text-yellow-500 text-[20px]"
                                          style="font-variation-settings: 'FILL' 1"
                                          title="Công thức nổi bật">star</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-gray-300 text-[20px]" title="Không nổi bật">star</span>
                                }
                            </td>
                            <td>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border @statusClass">
                                    @statusLabel
                                </span>
                            </td>
                            <td>
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-controller="ManagerRecipes" asp-action="Action" asp-route-id="@item.Id"
                                       class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-primary-container hover:bg-primary-fixed transition-colors"
                                       title="Sửa">
                                        <span class="material-symbols-outlined text-[18px]">edit</span>
                                    </a>
                                    <a asp-controller="ManagerRecipes" asp-action="Action" asp-route-cloneId="@item.Id"
                                       class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-blue-600 hover:bg-blue-50 transition-colors"
                                       title="Nhân bản">
                                        <span class="material-symbols-outlined text-[18px]">content_copy</span>
                                    </a>
                                    <form asp-controller="ManagerRecipes" asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline"
                                          data-admin-delete-form
                                          data-confirm-message="Bạn có chắc muốn xóa công thức này?">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-red-600 hover:bg-red-50 transition-colors"
                                                title="Xóa">
                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_AdminPageEnd" />
