@model UserFormViewModel
@{
    Layout = "_LayoutAdmin";
    ViewData["ActiveMenu"] = "members";
    var pageTitle = Model.IsEdit ? "Sửa thành viên" : "Thêm thành viên";
    ViewData["Title"] = pageTitle;
    ViewData["HeaderTitle"] = pageTitle;
    ViewData["HeaderSubtitle"] = Model.IsEdit
        ? "Cập nhật thông tin tài khoản"
        : "Tạo tài khoản người dùng mới";
}

<partial name="_AdminPageStart" />

<a asp-controller="ManagerUsers" asp-action="Index" class="admin-link-back">
    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
    Quay lại danh sách
</a>

<div class="admin-card admin-card--padded max-w-2xl">
    <form asp-controller="ManagerUsers" asp-action="Action" asp-route-id="@Model.Id" method="post" class="space-y-5">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

        <div>
            <label asp-for="Name" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <input asp-for="Name"
                   class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none" />
            <span asp-validation-for="Name" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Username" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <input asp-for="Username"
                   class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none" />
            <span asp-validation-for="Username" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Password" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <input asp-for="Password" type="password"
                   class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none"
                   placeholder="@(Model.IsEdit ? "Để trống nếu không đổi mật khẩu" : "Nhập mật khẩu")" />
            <span asp-validation-for="Password" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Role" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <select asp-for="Role"
                    class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none">
                <option value="@((int)UserRole.User)">Thành viên</option>
                <option value="@((int)UserRole.Editor)">Biên tập</option>
                <option value="@((int)UserRole.Admin)">Admin</option>
            </select>
            <span asp-validation-for="Role" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div>
            <label asp-for="Status" class="block text-sm font-medium text-on-surface mb-1.5"></label>
            <select asp-for="Status"
                    class="w-full px-4 py-2.5 rounded-lg border border-outline-variant bg-surface-container-lowest focus:border-primary-container focus:ring-1 focus:ring-primary-container text-sm outline-none">
                <option value="@((int)RecordStatus.Active)">Hoạt động</option>
                <option value="@((int)RecordStatus.Inactive)">Ẩn</option>
                <option value="@((int)RecordStatus.Draft)">Nháp</option>
            </select>
            <span asp-validation-for="Status" class="text-red-600 text-xs mt-1 block"></span>
        </div>

        <div class="flex items-center gap-3 pt-2">
            <button type="submit" class="admin-btn-primary">
                <span class="material-symbols-outlined text-[18px]">save</span>
                @(Model.IsEdit ? "Cập nhật" : "Tạo mới")
            </button>
            <a asp-controller="ManagerUsers" asp-action="Index"
               class="inline-flex items-center gap-2 px-6 py-2.5 rounded-lg border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors text-sm">
                Hủy
            </a>
        </div>
    </form>
</div>

<partial name="_AdminPageEnd" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
