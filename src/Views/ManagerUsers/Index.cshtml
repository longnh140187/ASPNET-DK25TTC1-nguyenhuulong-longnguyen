@model IEnumerable<User>
@{
    Layout = "_LayoutAdmin";
    ViewData["ActiveMenu"] = "members";
    ViewData["Title"] = "Quản lý thành viên";
    ViewData["HeaderTitle"] = "Thành viên";
    ViewData["HeaderSubtitle"] = "Quản lý tài khoản người dùng";
}

@functions {
    (string Label, string BadgeClass) GetStatusBadge(int status) => status switch
    {
        (int)RecordStatus.Active => ("Hoạt động", "bg-green-100 text-green-700 border-green-200"),
        (int)RecordStatus.Draft => ("Nháp", "bg-yellow-100 text-yellow-700 border-yellow-200"),
        _ => ("Ẩn", "bg-gray-100 text-gray-600 border-gray-200")
    };

    (string Label, string BadgeClass) GetRoleBadge(int role) => role switch
    {
        (int)UserRole.Admin => ("Admin", "bg-orange-100 text-orange-700 border-orange-200"),
        (int)UserRole.Editor => ("Biên tập", "bg-purple-100 text-purple-700 border-purple-200"),
        _ => ("Thành viên", "bg-blue-100 text-blue-700 border-blue-200")
    };
}

<partial name="_AdminPageStart" />

<div class="admin-toolbar">
    <a asp-controller="ManagerUsers" asp-action="Action" class="admin-btn-primary">
        <span class="material-symbols-outlined text-[18px]">add</span>
        Thêm thành viên
    </a>
</div>

<div class="admin-card">
    <div class="admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th class="text-right">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-on-surface-variant py-8">
                            Chưa có thành viên nào. Hãy thêm tài khoản đầu tiên.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        var (statusLabel, statusClass) = GetStatusBadge(item.Status);
                        var (roleLabel, roleClass) = GetRoleBadge(item.Role);
                        <tr>
                            <td>
                                <span class="font-medium text-on-surface">@(string.IsNullOrWhiteSpace(item.Name) ? "—" : item.Name)</span>
                            </td>
                            <td>
                                <span class="text-on-surface-variant font-mono text-sm">@item.Username</span>
                            </td>
                            <td>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border @roleClass">
                                    @roleLabel
                                </span>
                            </td>
                            <td>
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border @statusClass">
                                    @statusLabel
                                </span>
                            </td>
                            <td>
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-controller="ManagerUsers" asp-action="Action" asp-route-id="@item.Id"
                                       class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-primary-container hover:bg-primary-fixed transition-colors"
                                       title="Sửa">
                                        <span class="material-symbols-outlined text-[18px]">edit</span>
                                    </a>
                                    <form asp-controller="ManagerUsers" asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline"
                                          data-admin-delete-form
                                          data-confirm-message="Bạn có chắc muốn xóa thành viên này?">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:text-red-600 hover:bg-red-50 transition-colors"
                                                title="Xóa">
                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<partial name="_AdminPageEnd" />
