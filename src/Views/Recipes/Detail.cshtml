@model RecipeWebsite.Web.ViewModels.RecipeDetailViewModel
@{
ViewData["Title"] = Model.Title;
}

<div class="recipe-detail max-w-container-max mx-auto px-margin-mobile md:px-gutter py-8 space-y-section-gap">
    <!-- Hero Section -->
    <section
        class="grid grid-cols-1 md:grid-cols-2 gap-stack-lg items-center bg-surface-container-lowest p-6 md:p-10 rounded-xl shadow-sm overflow-hidden">
        <div class="relative rounded-lg overflow-hidden group aspect-square lg:aspect-video md:aspect-square">
            <img alt="@Model.Title"
                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                 src="@Model.ThumbnailUrl">
            @if (Model.IsPopular)
            {
            <div
                class="absolute top-4 left-4 bg-primary-container text-on-primary-container px-3 py-1 rounded-full font-label-md text-label-md shadow-md">
                Phổ biến nhất
            </div>
            }
        </div>
        <div class="space-y-stack-md">
            <nav class="flex items-center gap-2 text-label-md text-on-surface-variant">
                <a class="hover:text-primary" asp-controller="Recipes" asp-action="Index">@Model.CategoryName</a>
                <span>/</span>
                <span class="text-on-surface">@Model.SubCategoryName</span>
            </nav>
            <h1 class="font-headline-lg text-headline-lg md:text-display-lg text-on-surface leading-tight">@Model.Title</h1>
            <p class="text-body-lg text-on-surface-variant leading-relaxed">@Model.Summary</p>
            <div class="flex flex-wrap gap-stack-lg py-4 border-y border-outline-variant">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">schedule</span>
                    <div>
                        <p class="text-label-md font-bold text-on-surface">Thời gian</p>
                        <p class="text-body-md text-on-surface-variant">@Model.CookingTimeMinutes phút</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">equalizer</span>
                    <div>
                        <p class="text-label-md font-bold text-on-surface">Độ khó</p>
                        <p class="text-body-md text-on-surface-variant">@Model.DifficultyLabel</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary"
                          style="font-variation-settings: 'FILL' 1;">star</span>
                    <div>
                        <p class="text-label-md font-bold text-on-surface">Đánh giá</p>
                        <p class="text-body-md text-on-surface-variant">@Model.RatingLabel</p>
                    </div>
                </div>
            </div>
            <div class="flex flex-wrap gap-stack-md pt-4">
                <button type="button"
                        class="bg-primary-container text-on-primary px-8 py-3 rounded-lg font-headline-sm flex items-center gap-2 hover:opacity-90 transition-all active:scale-95">
                    <span class="material-symbols-outlined">favorite</span> Lưu vào yêu thích
                </button>
                <button type="button"
                        class="border-2 border-primary text-primary px-6 py-3 rounded-lg font-headline-sm flex items-center gap-2 hover:bg-primary-fixed transition-all active:scale-95">
                    <span class="material-symbols-outlined">print</span> In công thức
                </button>
                <button type="button"
                        class="p-3 border-2 border-outline-variant text-on-surface-variant rounded-lg hover:bg-surface-variant transition-all">
                    <span class="material-symbols-outlined">share</span>
                </button>
            </div>
        </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-stack-lg">
        <div class="lg:col-span-1 space-y-stack-lg">
            <!-- Ingredients -->
            <section class="bg-surface-container-low p-6 rounded-xl border border-outline-variant">
                <h2 class="font-headline-md text-headline-md text-on-surface mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">shopping_basket</span> Nguyên liệu
                </h2>
                <ul class="space-y-4">
                    @foreach (var ingredient in Model.Ingredients)
                    {
                    <li class="flex items-start gap-3 group cursor-pointer">
                        <input
                            class="mt-1 rounded text-primary focus:ring-primary-container border-outline cursor-pointer"
                            type="checkbox">
                        <span
                            class="text-body-lg text-on-surface group-hover:text-primary transition-colors">@ingredient</span>
                    </li>
                    }
                </ul>
            </section>

            @if (Model.Nutrition is not null)
            {
            <!-- Nutrition -->
            <section class="bg-inverse-surface text-inverse-on-surface p-6 rounded-xl shadow-lg">
                <h2 class="font-headline-sm text-headline-sm mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined">analytics</span> Giá trị dinh dưỡng
                </h2>
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-surface-container/10 p-3 rounded-lg text-center">
                        <p class="text-label-md opacity-80 uppercase tracking-wider">Calories</p>
                        <p class="text-headline-md font-bold">@Model.Nutrition.Calories</p>
                    </div>
                    <div class="bg-surface-container/10 p-3 rounded-lg text-center">
                        <p class="text-label-md opacity-80 uppercase tracking-wider">Protein</p>
                        <p class="text-headline-md font-bold">@Model.Nutrition.Protein</p>
                    </div>
                    <div class="bg-surface-container/10 p-3 rounded-lg text-center">
                        <p class="text-label-md opacity-80 uppercase tracking-wider">Chất béo</p>
                        <p class="text-headline-md font-bold">@Model.Nutrition.Fat</p>
                    </div>
                    <div class="bg-surface-container/10 p-3 rounded-lg text-center">
                        <p class="text-label-md opacity-80 uppercase tracking-wider">Carbs</p>
                        <p class="text-headline-md font-bold">@Model.Nutrition.Carbs</p>
                    </div>
                </div>
            </section>
            }
        </div>

        <!-- Instructions -->
        <div class="lg:col-span-2">
            <section class="bg-surface-container-lowest p-6 md:p-8 rounded-xl border border-outline-variant shadow-sm">
                <h2 class="font-headline-lg text-headline-lg text-on-surface mb-8 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-4xl">restaurant_menu</span> Các bước thực
                    hiện
                </h2>
                <div class="space-y-10">
                    @for (var i = 0; i < Model.Steps.Count; i++)
                    {
                    var step = Model.Steps[i];
                    <div class="flex items-start">
                        <div class="step-number" data-step="@(i + 1)"></div>
                        <div class="space-y-2">
                            <h3 class="font-headline-sm text-headline-sm text-on-surface">@step.Title</h3>
                            <p class="text-body-lg text-on-surface-variant">@step.Description</p>
                        </div>
                    </div>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.ChefTip))
                {
                <div class="mt-12 p-6 bg-secondary-container/20 border-l-4 border-secondary rounded-r-lg">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="material-symbols-outlined text-secondary">lightbulb</span>
                        <span class="font-headline-sm text-secondary">Mẹo từ Chef</span>
                    </div>
                    <p class="text-body-lg text-on-secondary-container italic">"@Model.ChefTip"</p>
                </div>
                }
            </section>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/recipes-detail.js" asp-append-version="true"></script>
}
