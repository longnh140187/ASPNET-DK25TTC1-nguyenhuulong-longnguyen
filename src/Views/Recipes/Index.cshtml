@model RecipeIndexViewModel
@using RecipeWebsite.Web.Models
@{
    ViewData["Title"] = "Công thức";
    var recipesBaseUrl = Url.Action("Index", "Recipes") ?? "/recipes";
}

<div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter py-stack-lg md:py-section-gap">
    
    <div class="mb-stack-lg">
        <nav aria-label="Breadcrumb" class="flex text-on-surface-variant text-xs mb-stack-sm">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a class="inline-flex items-center hover:text-primary-container transition-colors" asp-controller="Home"
                       asp-action="Index">
                        <span class="material-symbols-outlined text-[14px] mr-1">home</span>
                        Trang chủ
                    </a>
                </li>
                <li>
                    <div class="flex items-center">
                        <span class="material-symbols-outlined text-[14px] mx-1">chevron_right</span>
                        <span aria-current="page" class="text-primary-container font-medium">Công thức</span>
                    </div>
                </li>
            </ol>
        </nav>
        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            <h1 class="font-headline-md text-headline-md text-on-surface">Kết quả tìm kiếm</h1>
            <p class="text-body-md text-on-surface-variant mt-2 max-w-2xl">
                Tìm thấy <strong class="text-on-surface">@Model.TotalItems</strong> công thức cho
                &ldquo;<span class="text-primary-container">@Model.SearchQuery</span>&rdquo;
            </p>
        }
        else
        {
            <h1 class="font-headline-md text-headline-md text-on-surface">Tất cả Công thức</h1>
            <p class="text-body-md text-on-surface-variant mt-2 max-w-2xl">Khám phá hàng ngàn công thức nấu ăn
                ngon miệng, từ bữa cơm gia đình giản dị đến những món tiệc sang trọng.</p>
        }
    </div>

    <form method="get" asp-controller="Recipes" asp-action="Index" id="recipeFilterForm"
          class="flex flex-col lg:flex-row gap-stack-lg items-start">
        <input type="hidden" name="page" id="pageInput" value="@Model.CurrentPage"/>
        @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            <input type="hidden" name="q" value="@Model.SearchQuery"/>
        }

        <aside
            class="w-full lg:w-64 flex-shrink-0 bg-surface-container-lowest border border-outline-variant rounded-xl p-stack-md sticky top-24 shadow-[0_4px_20px_rgba(0,0,0,0.05)]">
            <div
                class="flex items-center justify-between mb-stack-md pb-stack-sm border-b border-outline-variant">
                <h2 class="font-semibold text-body-md flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">filter_list</span>
                    Bộ lọc
                </h2>
                @if (Model.HasActiveFilters)
                {
                    <a asp-controller="Recipes" asp-action="Index"
                       class="text-primary-container text-label-md hover:underline">Xóa tất cả</a>
                }
                else
                {
                    <span class="text-on-surface-variant text-label-md opacity-50 cursor-not-allowed">Xóa tất cả</span>
                }
            </div>
            
            <div class="mb-stack-lg">
                <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-stack-sm">
                    Danh mục</h3>
                <div class="space-y-2">
                    @if (!Model.Categories.Any())
                    {
                        <p class="text-label-md text-on-surface-variant">Chưa có danh mục.</p>
                    }
                    else
                    {
                        @foreach (var category in Model.Categories)
                        {
                            var isChecked = Model.SelectedCategoryIds.Contains(category.Id);
                            <label class="flex items-center gap-2 cursor-pointer group">
                                <input class="filter-input rounded border-outline text-primary-container focus:ring-primary-container"
                                       type="checkbox" name="categoryIds" value="@category.Id"
                                       checked="@isChecked"/>
                                <span class="text-label-md group-hover:text-primary-container transition-colors">@category.Name</span>
                            </label>
                        }
                    }
                </div>
            </div>
            
            <div class="mb-stack-lg">
                <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-stack-sm">Độ
                    khó</h3>
                <div class="flex flex-wrap gap-2">
                    @{
                        var difficultyOptions = new[]
                        {
                            (Value: nameof(RecipeDifficulty.EASY), Label: "Dễ"),
                            (Value: nameof(RecipeDifficulty.MEDIUM), Label: "Trung bình"),
                            (Value: nameof(RecipeDifficulty.HARD), Label: "Khó")
                        };
                    }
                    @foreach (var option in difficultyOptions)
                    {
                        var isSelected = Model.SelectedDifficulties.Contains(option.Value);
                        <label class="cursor-pointer">
                            <input type="checkbox" name="difficulties" value="@option.Value"
                                   class="filter-input peer sr-only" checked="@isSelected"/>
                            <span class="inline-block px-2.5 py-0.5 rounded-full border text-label-md transition-colors
                                peer-checked:border-primary-container peer-checked:text-primary-container peer-checked:bg-primary-fixed/20
                                @(isSelected
                                    ? "border-primary-container text-primary-container bg-primary-fixed/20"
                                    : "border-outline text-on-surface-variant bg-surface hover:border-primary-container hover:text-primary-container")">
                                @option.Label
                            </span>
                        </label>
                    }
                </div>
            </div>
            
            <div>
                <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-stack-sm">
                    Thời gian nấu</h3>
                <input id="maxTimeRange"
                       name="maxTime"
                       class="filter-input w-full accent-primary-container h-1 bg-surface-container rounded-lg appearance-none cursor-pointer"
                       max="@RecipeIndexViewModel.MaxCookingTimeLimit" min="10" type="range"
                       value="@Model.MaxTime"/>
                <div class="flex justify-between text-label-md text-on-surface-variant mt-1">
                    <span>10p</span>
                    <span id="maxTimeLabel">
                        @if (Model.MaxTime >= RecipeIndexViewModel.MaxCookingTimeLimit)
                        {
                            @:≤ 120p+
                        }
                        else
                        {
                            @:<span>≤ @Model.MaxTime p</span>
                        }
                    </span>
                    <span>120p+</span>
                </div>
            </div>
        </aside>

        <div class="flex-1 min-w-0">
            
            <div
                class="flex flex-col sm:flex-row justify-between items-center gap-stack-md mb-stack-lg bg-surface-container-lowest p-2 rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.02)] border border-outline-variant">
                <div class="flex items-center gap-2 w-full sm:w-auto">
                    <span class="font-label-md text-label-md text-on-surface-variant whitespace-nowrap">Hiển thị:</span>
                    <select id="pageSizeSelect" name="pageSize"
                            class="filter-input bg-surface-container border-none rounded-lg py-2 pl-3 pr-8 focus:ring-2 focus:ring-primary-container text-sm cursor-pointer w-full sm:w-auto">
                        @foreach (var size in RecipeIndexViewModel.AllowedPageSizes)
                        {
                            if (Model.PageSize == size)
                            {
                                <option value="@size" selected>@size / trang</option>
                            }
                            else
                            {
                                <option value="@size">@size / trang</option>
                            }
                        }
                    </select>
                </div>
                <div class="flex items-center gap-2 w-full sm:w-auto">
                    <span
                        class="font-label-md text-label-md text-on-surface-variant whitespace-nowrap">Sắp xếp theo:</span>
                    <select id="sortBySelect" name="sortBy"
                            class="filter-input bg-surface-container border-none rounded-lg py-2 pl-3 pr-8 focus:ring-2 focus:ring-primary-container text-sm cursor-pointer w-full sm:w-auto">
                        @foreach (var option in new[] { RecipeSortBy.Newest, RecipeSortBy.Popular, RecipeSortBy.Fastest })
                        {
                            var label = option switch
                            {
                                RecipeSortBy.Popular => "Phổ biến",
                                RecipeSortBy.Fastest => "Nhanh nhất",
                                _ => "Mới nhất"
                            };
                            if (Model.SortBy == option)
                            {
                                <option value="@option" selected>@label</option>
                            }
                            else
                            {
                                <option value="@option">@label</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-stack-md">
                @if (!Model.Recipes.Any())
                {
                    <div class="md:col-span-3 text-center py-16 text-on-surface-variant">
                        @if (Model.HasActiveFilters)
                        {
                            @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                            {
                                <p class="mb-2">Không tìm thấy công thức nào khớp với &ldquo;@Model.SearchQuery&rdquo;.</p>
                            }
                            else
                            {
                                <p class="mb-2">Không tìm thấy công thức phù hợp với bộ lọc.</p>
                            }
                            <a asp-controller="Recipes" asp-action="Index"
                               class="text-primary-container hover:underline text-sm">Xóa bộ lọc</a>
                        }
                        else
                        {
                            <p>Chưa có công thức nào.</p>
                        }
                    </div>
                }
                else
                {
                    @foreach (var recipe in Model.Recipes)
                    {
                        <partial name="_RecipeListCard" model="recipe"/>
                    }
                }
            </div>

            @if (Model.TotalItems > 0)
            {
                <div class="mt-stack-lg flex flex-col sm:flex-row items-center justify-between gap-4">
                    <p class="text-sm text-on-surface-variant">
                        Trang @Model.CurrentPage / @Model.TotalPages
                        <span class="hidden sm:inline">— @Model.TotalItems công thức</span>
                    </p>
                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Pagination" class="flex items-center gap-1">
                            @if (Model.HasPreviousPage)
                            {
                                <a href="@(recipesBaseUrl + Model.BuildQueryString(Model.CurrentPage - 1))"
                                   class="w-9 h-9 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant hover:bg-surface-container hover:text-primary-container transition-colors"
                                   title="Trang trước">
                                    <span class="material-symbols-outlined">chevron_left</span>
                                </a>
                            }
                            else
                            {
                                <span
                                    class="w-9 h-9 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant opacity-50 cursor-not-allowed">
                                    <span class="material-symbols-outlined">chevron_left</span>
                                </span>
                            }

                            @for (var p = 1; p <= Model.TotalPages; p++)
                            {
                                if (p == Model.CurrentPage)
                                {
                                    <span
                                        class="w-9 h-9 flex items-center justify-center rounded-full bg-primary-container text-white text-sm font-bold">@p</span>
                                }
                                else
                                {
                                    <a href="@(recipesBaseUrl + Model.BuildQueryString(p))"
                                       class="w-9 h-9 flex items-center justify-center rounded-full border border-outline-variant text-on-surface hover:bg-surface-container hover:text-primary-container transition-colors text-sm">
                                        @p
                                    </a>
                                }
                            }

                            @if (Model.HasNextPage)
                            {
                                <a href="@(recipesBaseUrl + Model.BuildQueryString(Model.CurrentPage + 1))"
                                   class="w-9 h-9 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant hover:bg-surface-container hover:text-primary-container transition-colors"
                                   title="Trang sau">
                                    <span class="material-symbols-outlined">chevron_right</span>
                                </a>
                            }
                            else
                            {
                                <span
                                    class="w-9 h-9 flex items-center justify-center rounded-full border border-outline-variant text-on-surface-variant opacity-50 cursor-not-allowed">
                                    <span class="material-symbols-outlined">chevron_right</span>
                                </span>
                            }
                        </nav>
                    }
                </div>
            }
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
            var form = document.getElementById('recipeFilterForm');
            var pageInput = document.getElementById('pageInput');
            var maxTimeRange = document.getElementById('maxTimeRange');
            var maxTimeLabel = document.getElementById('maxTimeLabel');
            var maxLimit = @RecipeIndexViewModel.MaxCookingTimeLimit;
            var rangeTimer;

            function updateMaxTimeLabel(value) {
                if (!maxTimeLabel) return;
                maxTimeLabel.textContent = Number(value) >= maxLimit ? '≤ 120p+' : '≤ ' + value + ' p';
            }

            function submitFromPageOne() {
                if (pageInput) pageInput.value = '1';
                form?.submit();
            }

            document.querySelectorAll('.filter-input').forEach(function (el) {
                if (el === maxTimeRange) return;

                el.addEventListener('change', function () {
                    submitFromPageOne();
                });
            });

            maxTimeRange?.addEventListener('input', function () {
                updateMaxTimeLabel(this.value);
                clearTimeout(rangeTimer);
                rangeTimer = setTimeout(submitFromPageOne, 400);
            });

            updateMaxTimeLabel(maxTimeRange?.value ?? maxLimit);
        })();
    </script>
}
