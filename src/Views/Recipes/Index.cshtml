@{
ViewData["Title"] = "Công thức";
}

<div class="max-w-container-max mx-auto px-margin-mobile md:px-gutter py-stack-lg md:py-section-gap">
    <!-- Breadcrumbs & Header -->
    <div class="mb-stack-lg">
        <nav aria-label="Breadcrumb" class="flex text-on-surface-variant text-xs mb-stack-sm">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a class="inline-flex items-center hover:text-primary-container transition-colors" asp-controller="Home"
                       asp-action="Index">
                        <span class="material-symbols-outlined text-[14px] mr-1">home</span>
                        Trang chủ
                    </a>
                </li>
                <li>
                    <div class="flex items-center">
                        <span class="material-symbols-outlined text-[14px] mx-1">chevron_right</span>
                        <span aria-current="page" class="text-primary-container font-medium">Công thức</span>
                    </div>
                </li>
            </ol>
        </nav>
        <h1 class="font-headline-md text-headline-md text-on-surface">Tất cả Công thức</h1>
        <p class="text-body-md text-on-surface-variant mt-2 max-w-2xl">Khám phá hàng ngàn công thức nấu ăn
            ngon miệng, từ bữa cơm gia đình giản dị đến những món tiệc sang trọng.</p>
    </div>
    <div class="flex flex-col lg:flex-row gap-stack-lg items-start">
        <!-- Sidebar Filters -->
        <aside
            class="w-full lg:w-64 flex-shrink-0 bg-surface-container-lowest border border-outline-variant rounded-xl p-stack-md sticky top-24 shadow-[0_4px_20px_rgba(0,0,0,0.05)]">
            <div
                class="flex items-center justify-between mb-stack-md pb-stack-sm border-b border-outline-variant">
                <h2 class="font-semibold text-body-md flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">filter_list</span>
                    Bộ lọc
                </h2>
                <button class="text-primary-container text-label-md">Xóa tất cả</button>
            </div>
            <!-- Categories -->
            <div class="mb-stack-lg">
                <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-stack-sm">
                    Danh mục</h3>
                <div class="space-y-2">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input checked=""
                               class="rounded border-outline text-primary-container focus:ring-primary-container"
                               type="checkbox"/>
                        <span
                            class="text-label-md group-hover:text-primary-container transition-colors">Món chính</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input class="rounded border-outline text-primary-container focus:ring-primary-container"
                               type="checkbox"/>
                        <span
                            class="text-label-md group-hover:text-primary-container transition-colors">Ăn chay</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input class="rounded border-outline text-primary-container focus:ring-primary-container"
                               type="checkbox"/>
                        <span
                            class="text-label-md group-hover:text-primary-container transition-colors">Tráng miệng</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input class="rounded border-outline text-primary-container focus:ring-primary-container"
                               type="checkbox"/>
                        <span
                            class="text-label-md group-hover:text-primary-container transition-colors">Đồ uống</span>
                    </label>
                </div>
            </div>
            <!-- Difficulty -->
            <div class="mb-stack-lg">
                <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-stack-sm">Độ
                    khó</h3>
                <div class="flex flex-wrap gap-2">
                    <button
                        class="px-2.5 py-0.5 rounded-full border border-primary-container text-primary-container bg-primary-fixed/20 text-label-md hover:bg-primary-container hover:text-white transition-colors">
                        Dễ
                    </button>
                    <button
                        class="px-2.5 py-0.5 rounded-full border border-outline text-on-surface-variant bg-surface text-label-md hover:border-primary-container hover:text-primary-container transition-colors">
                        Trung bình
                    </button>
                    <button
                        class="px-2.5 py-0.5 rounded-full border border-outline text-on-surface-variant bg-surface text-label-md hover:border-primary-container hover:text-primary-container transition-colors">
                        Khó
                    </button>
                </div>
            </div>
            <!-- Time -->
            <div>
                <h3 class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider mb-stack-sm">
                    Thời gian nấu</h3>
                <input
                    class="w-full accent-primary-container h-1 bg-surface-container rounded-lg appearance-none cursor-pointer"
                    max="120" min="10" type="range" value="60"/>
                <div class="flex justify-between text-label-md text-on-surface-variant mt-1">
                    <span>10p</span>
                    <span>&lt; 60p</span>
                    <span>120p+</span>
                </div>
            </div>
        </aside>
        <!-- Main Content Area -->
        <div class="flex-1 min-w-0">
            <!-- Search & Sort Bar -->
            <div
                class="flex flex-col sm:flex-row justify-between items-center gap-stack-md mb-stack-lg bg-surface-container-lowest p-2 rounded-xl shadow-[0_4px_20px_rgba(0,0,0,0.02)] border border-outline-variant">
                <div class="relative w-full sm:w-96">
                    <span
                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
                    <input
                        class="w-full pl-10 pr-4 py-2 bg-surface-container border-none rounded-lg focus:ring-2 focus:ring-primary-container text-sm"
                        placeholder="Tìm kiếm công thức..." type="text"/>
                </div>
                <div class="flex items-center gap-2 w-full sm:w-auto">
                    <span
                        class="font-label-md text-label-md text-on-surface-variant whitespace-nowrap">Sắp xếp theo:</span>
                    <select
                        class="bg-surface-container border-none rounded-lg py-2 pl-3 pr-8 focus:ring-2 focus:ring-primary-container text-sm cursor-pointer w-full sm:w-auto">
                        <option>Mới nhất</option>
                        <option>Phổ biến</option>
                        <option>Nhanh nhất</option>
                    </select>
