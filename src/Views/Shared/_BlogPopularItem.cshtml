@model Blog
@using RecipeWebsite.Web.ViewModels
@{
    var hasThumbnail = !string.IsNullOrWhiteSpace(Model.ThumbnailUrl);
}

<a class="flex gap-4 group items-center" asp-controller="Blogs" asp-action="Detail" asp-route-slug="@Model.Slug">
    <div class="w-20 h-20 rounded-lg overflow-hidden shrink-0 bg-surface-container">
        @if (hasThumbnail)
        {
            <img alt="@Model.Title"
                 class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                 src="@Model.ThumbnailUrl" loading="lazy"/>
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center text-on-surface-variant">
                <span class="material-symbols-outlined">article</span>
            </div>
        }
    </div>
    <div class="flex flex-col gap-1 min-w-0">
        <h5 class="text-body-md font-bold leading-snug group-hover:text-primary transition-colors line-clamp-2">@Model.Title</h5>
        <span class="text-label-md text-on-surface-variant">@BlogIndexViewModel.FormatDate(Model.CreatedAt)</span>
    </div>
</a>
