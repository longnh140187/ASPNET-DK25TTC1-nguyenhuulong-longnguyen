@model (RecipeWebsite.Web.Models.Blog Blog, int Index)
@using RecipeWebsite.Web.ViewModels
@{
    var blog = Model.Blog;
    var (tagLabel, _) = BlogIndexViewModel.GetTagForBlog(blog, Model.Index);
    var hasThumbnail = !string.IsNullOrWhiteSpace(blog.ThumbnailUrl);
}

<a asp-controller="Blogs" asp-action="Detail" asp-route-slug="@blog.Slug"
   class="bg-surface-container-lowest rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all group flex flex-col h-full border border-outline-variant">
    <div class="h-56 overflow-hidden relative bg-surface-container">
        @if (hasThumbnail)
        {
            <img alt="@blog.Title"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                 src="@blog.ThumbnailUrl" loading="lazy"/>
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center text-on-surface-variant">
                <span class="material-symbols-outlined text-5xl">article</span>
            </div>
        }
        <span class="absolute top-4 left-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-full text-label-md font-bold text-primary">
            @tagLabel
        </span>
    </div>
    <div class="p-6 flex flex-col grow">
        <h3 class="font-headline-sm text-headline-sm mb-3 group-hover:text-primary transition-colors line-clamp-2">@blog.Title</h3>
        @if (!string.IsNullOrWhiteSpace(blog.Summary))
        {
            <p class="text-on-surface-variant text-body-md line-clamp-2 mb-6">@blog.Summary</p>
        }
        <div class="mt-auto flex items-center justify-between border-t border-outline-variant pt-4">
            <span class="text-label-md text-on-surface-variant">@BlogIndexViewModel.FormatDate(blog.CreatedAt)</span>
            <span class="inline-flex items-center gap-1 text-primary text-label-md font-bold">
                Đọc thêm
                <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </span>
        </div>
    </div>
</a>
