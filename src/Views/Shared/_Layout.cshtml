<!DOCTYPE html>
<html lang="vi">
<head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <title>@ViewData["Title"] - Nấu Ngon Mỗi Ngày</title>
        <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        <script src="~/js/tailwind.config.js" asp-append-version="true"></script>
        <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&amp;display=swap"
              rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&amp;display=swap"
              rel="stylesheet">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="font-sans text-on-surface bg-surface">
@{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var homeNavClass = currentController == "Home"
                ? "text-primary-container border-b-2 border-primary-container pb-1"
                : "hover:text-primary-container transition-colors";
        var recipesNavClass = currentController == "Recipes"
                ? "text-primary-container border-b-2 border-primary-container pb-1"
                : "hover:text-primary-container transition-colors";
        var blogsNavClass = currentController == "Blogs"
                ? "text-primary-container border-b-2 border-primary-container pb-1"
                : "hover:text-primary-container transition-colors";
}

<header class="sticky top-0 z-50 bg-surface-container-lowest border-b border-outline-variant py-3 shadow-sm">
        <div class="container mx-auto px-4 lg:px-8 flex items-center justify-between">
                
                <a class="flex items-center gap-2" asp-controller="Home" asp-action="Index"><img
                                alt="Nấu Ngon Mỗi Ngày Logo" class="h-10 w-auto object-cover"
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBxL4aNBgSTPcDK98YWBgY6iwpwNFIS9QHv2Na6l9O5PzZs2YhRTa6QfS0PdvXMF0jML8_eZquZEDIFkv2T0SXkEzAIym7iKFjHs2rnKRvwdciPbhfrcELRh43msSy5kPrUip7OgisnrHZY320lSmOW8JIWq3euPZH7hRny7IEkVoiL0pNcSYXjdXqqiK7z0TAii93CFXd-ScJwalaI-v0WTplFBQFccRwAVzncmPErKKBnqucPVdeVf2-HN7URxpbtOwcaJZrhhbg"></a>
                
                <nav class="hidden lg:flex items-center gap-6 font-medium text-on-surface-variant">
                        <a class="@homeNavClass" asp-controller="Home"
                           asp-action="Index">Trang chủ</a>
                        <a class="@recipesNavClass" asp-controller="Recipes"
                           asp-action="Index">Công thức</a>
                        <a class="hover:text-primary-container transition-colors" asp-controller="ComingSoon" asp-action="Index" asp-route-feature="Món ngon">Món ngon</a>
                        <a class="@blogsNavClass" asp-controller="Blogs" asp-action="Index">Blog</a>
                </nav>
                
                <div class="flex items-center gap-4">
                        <form asp-controller="Recipes" asp-action="Index" method="get"
                              class="hidden md:flex relative text-on-surface-variant focus-within:text-on-surface">
                                <input name="q"
                                       value="@Context.Request.Query["q"]"
                                       class="pr-10 pl-4 py-2 bg-surface-container border border-outline-variant rounded-full text-sm focus:outline-none focus:ring-1 focus:ring-primary-container focus:border-primary-container w-64 transition-all"
                                       placeholder="Tìm kiếm công thức, món ăn..." type="search">
                                <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2"
                                        aria-label="Tìm kiếm">
                                        <i class="fa-solid fa-magnifying-glass"></i>
                                </button>
                        </form>
                </div>
        </div>
</header>

<main>
        @RenderBody()
</main>

<footer class="bg-surface-container-lowest border-t border-outline-variant pt-12 pb-6 mt-12">
        <div class="container mx-auto px-4 lg:px-8">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
                        
                        <div class="space-y-6">
                                <a class="flex items-center gap-2" asp-controller="Home" asp-action="Index"><img
                                                alt="Nấu Ngon Mỗi Ngày Logo" class="h-10 w-auto object-cover"
                                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBxL4aNBgSTPcDK98YWBgY6iwpwNFIS9QHv2Na6l9O5PzZs2YhRTa6QfS0PdvXMF0jML8_eZquZEDIFkv2T0SXkEzAIym7iKFjHs2rnKRvwdciPbhfrcELRh43msSy5kPrUip7OgisnrHZY320lSmOW8JIWq3euPZH7hRny7IEkVoiL0pNcSYXjdXqqiK7z0TAii93CFXd-ScJwalaI-v0WTplFBQFccRwAVzncmPErKKBnqucPVdeVf2-HN7URxpbtOwcaJZrhhbg"></a>
                                <p class="text-body-md text-on-surface-variant">
                                        Cộng đồng chia sẻ công thức nấu ăn ngon, bí quyết nấu nướng và ẩm thực phong phú
                                        từ khắp nơi trên thế giới.
                                </p>
                        </div>
                        
                        <div>
                                <h4 class="text-headline-sm text-on-surface mb-6">Khám phá</h4>
                                <ul class="space-y-3 text-body-md text-on-surface-variant">
                                        <li class=""><a class="hover:text-primary-container transition-colors"
                                                           asp-controller="Recipes" asp-action="Index">Công
                                                        thức</a></li>
                                        <li class=""><a class="hover:text-primary-container transition-colors"
                                                           asp-controller="Recipes" asp-action="Index">Món
                                                        ngon</a></li>
                                        <li class=""><a class="hover:text-primary-container transition-colors"
                                                           asp-controller="Recipes" asp-action="Index">Ẩm
                                                        thực</a></li>
                                        <li class=""><a class="hover:text-primary-container transition-colors"
                                                           asp-controller="Blogs" asp-action="Index">Blog</a>
                                        </li>
                                </ul>
                        </div>
                        
                        <div>
                                <h4 class="text-headline-sm text-on-surface mb-6">Hỗ trợ</h4>
                                <ul class="space-y-3 text-body-md text-on-surface-variant">
                                        <li class=""><a class="hover:text-primary-container transition-colors"
                                                           asp-controller="ComingSoon" asp-action="Index" asp-route-feature="Giới thiệu">Giới
                                                        thiệu</a></li>
                                        <li class=""><a class="hover:text-primary-container transition-colors"
                                                           asp-controller="ComingSoon" asp-action="Index" asp-route-feature="Liên hệ">Liên
                                                        hệ</a></li>
                                        <li class=""><a class="hover:text-primary-container transition-colors"
                                                           asp-controller="ComingSoon" asp-action="Index" asp-route-feature="Điều khoản sử dụng">Điều
                                                        khoản sử dụng</a></li>
                                        <li class=""><a class="hover:text-primary-container transition-colors"
                                                           asp-controller="ComingSoon" asp-action="Index" asp-route-feature="Chính sách bảo mật">Chính
                                                        sách bảo mật</a></li>
                                        <li class=""><a class="hover:text-primary-container transition-colors"
                                                           asp-controller="ComingSoon" asp-action="Index" asp-route-feature="Câu hỏi thường gặp">Câu
                                                        hỏi thường gặp</a></li>
                                </ul>
                        </div>
                </div>
                
                <div class="border-t border-outline-variant pt-6 flex flex-col md:flex-row justify-between items-center gap-4 text-label-md text-on-surface-variant">
                        <p class="">© 2024 Nấu Ngon Mỗi Ngày. Tất cả quyền được bảo lưu.</p>
                        <button type="button" id="scrollToTop" aria-label="Cuộn lên đầu trang"
                                class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center hover:bg-primary-container hover:text-white transition-all shadow-sm">
                                <i class="fa-solid fa-arrow-up"></i>
                        </button>
                </div>
        </div>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
