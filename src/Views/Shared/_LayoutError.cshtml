<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nấu Ngon Mỗi Ngày</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="font-sans text-on-surface bg-surface min-h-screen flex flex-col">
    <header class="bg-surface-container-lowest border-b border-outline-variant py-4">
        <div class="container mx-auto px-4 lg:px-8">
            <a asp-controller="Home" asp-action="Index">
                <img alt="Nấu Ngon Mỗi Ngày" class="h-10 w-auto object-cover"
                     src="https://lh3.googleusercontent.com/aida-public/AB6AXuBxL4aNBgSTPcDK98YWBgY6iwpwNFIS9QHv2Na6l9O5PzZs2YhRTa6QfS0PdvXMF0jML8_eZquZEDIFkv2T0SXkEzAIym7iKFjHs2rnKRvwdciPbhfrcELRh43msSy5kPrUip7OgisnrHZY320lSmOW8JIWq3euPZH7hRny7IEkVoiL0pNcSYXjdXqqiK7z0TAii93CFXd-ScJwalaI-v0WTplFBQFccRwAVzncmPErKKBnqucPVdeVf2-HN7URxpbtOwcaJZrhhbg">
            </a>
        </div>
    </header>

    <main class="flex-1 flex items-center justify-center px-4 py-12">
        @RenderBody()
    </main>

    <footer class="py-6 text-center text-sm text-on-surface-variant border-t border-outline-variant">
        &copy; @DateTime.Now.Year Nấu Ngon Mỗi Ngày
    </footer>
</body>
</html>
