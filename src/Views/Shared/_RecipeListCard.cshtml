@model Recipe
@functions {
    string GetDifficultyLabel(string difficulty) => difficulty switch
    {
        "EASY" => "Dễ",
        "MEDIUM" => "Trung bình",
        "HARD" => "Khó",
        _ => difficulty
    };
}
@{
    var categoryName = Model.Category?.Name ?? "Món ăn";
    var categoryColor = string.IsNullOrWhiteSpace(Model.Category?.Color) ? "#ff6b00" : Model.Category!.Color!;
    var hasThumbnail = !string.IsNullOrWhiteSpace(Model.ThumbnailUrl);
}

<article class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.05)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] transition-all duration-300 group flex flex-col h-full border border-outline-variant">
    <div class="relative h-48 overflow-hidden bg-surface-container">
        @if (hasThumbnail)
        {
            <img alt="@Model.Title"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                 src="@Model.ThumbnailUrl" loading="lazy"/>
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center text-on-surface-variant">
                <span class="material-symbols-outlined text-4xl">image</span>
            </div>
        }
        <div class="absolute top-3 left-3 text-white px-2 py-0.5 rounded-md text-[9px] uppercase tracking-wider font-bold"
             style="background-color: @categoryColor">
            @categoryName
        </div>
        <button type="button"
                class="absolute top-3 right-3 w-8 h-8 bg-white/80 backdrop-blur-sm rounded-full flex items-center justify-center text-on-surface-variant hover:text-primary-container hover:bg-white transition-colors">
            <span class="material-symbols-outlined text-[16px]">favorite</span>
        </button>
    </div>
    <div class="p-3 flex flex-col flex-1">
        <a asp-controller="Recipes" asp-action="Detail" asp-route-slug="@Model.Slug"
           class="font-semibold text-label-md text-on-surface mb-2 line-clamp-2 group-hover:text-primary-container transition-colors block">
            @Model.Title
        </a>
        @if (!string.IsNullOrWhiteSpace(Model.Summary))
        {
            <p class="text-on-surface-variant text-[11px] line-clamp-2 mb-2">@Model.Summary</p>
        }
        <div class="mt-auto pt-stack-sm flex items-center justify-start border-t border-outline-variant">
            <div class="flex items-center gap-3 text-on-surface-variant text-[11px]">
                @if (Model.CookingTimeMinutes is > 0)
                {
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[12px]">schedule</span> @Model.CookingTimeMinutes p
                    </span>
                }
                <span class="flex items-center gap-1">
                    <span class="material-symbols-outlined text-[12px]">local_fire_department</span> @GetDifficultyLabel(Model.Difficulty)
                </span>
            </div>
        </div>
    </div>
</article>
